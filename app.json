{
  "expo": {
    "name": "Evently",
    "slug": "evently",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "evently",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#fcf9f8"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "de.pakumedia.evently",
      "associatedDomains": [
        "applinks:evently.app"
      ]
    },
    "android": {
      "package": "de.pakumedia.evently",
      "softwareKeyboardLayoutMode": "resize",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#fcf9f8"
      },
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "evently.app",
              "pathPrefix": "/rsvp"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-localization",
      [
        "expo-font",
        {
          "fonts": []
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Evently braucht Zugriff auf deine Fotos, um Bilder zu Einladungskarten hinzuzufügen."
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Evently nutzt deinen Standort, um den Veranstaltungsort auf der Karte zu setzen.",
          "locationWhenInUsePermission": "Evently nutzt deinen Standort, um den Veranstaltungsort auf der Karte zu setzen."
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {}
    }
  }
}
